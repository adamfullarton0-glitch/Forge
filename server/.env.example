# Copy to .env and fill in. NEVER commit real secrets.

# Postgres connection string (required in production).
DATABASE_URL=postgres://user:password@localhost:5432/forge

# JWT signing secret. MUST be a long random value (>= 32 chars) in production.
# Generate one: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional overrides
PORT=8080
JWT_TTL_SECONDS=2592000        # 30 days
BCRYPT_ROUNDS=10
# Comma-separated allowed browser origins (the PWA). Use the deployed app URL.
# e.g. CORS_ORIGINS=https://adamfullarton0-glitch.github.io
CORS_ORIGINS=*
NODE_ENV=development
